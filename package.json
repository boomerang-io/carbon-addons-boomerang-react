{
  "name": "@boomerang-io/carbon-addons-boomerang-react",
  "description": "Carbon Addons for Boomerang apps",
  "version": "4.7.2-beta.2",
  "author": {
    "name": "Tim Bula",
    "email": "timrbula@gmail.com"
  },
  "license": "Apache-2",
  "repository": {
    "type": "git",
    "url": "git@github.com:boomerang-io/carbon-addons-boomerang-react"
  },
  "homepage": "https://carbon-addons-boomerang-react.netlify.app",
  "bugs": {
    "url": "https://github.com/boomerang-io/carbon-addons-boomerang-react/issues"
  },
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist/**/*",
    "scss/**/*"
  ],
  "sideEffects": false,
  "keywords": [
    "react",
    "carbon",
    "components",
    "boomerang",
    "storybook"
  ],
  "scripts": {
    "build": "rimraf scss dist && pnpm build:components && pnpm build:styles && pnpm build:types",
    "build:components": "rollup -c --bundleConfigAsCjs",
    "build:styles": "node scripts/build.js",
    "build:storybook": "storybook build",
    "build:types": "tsup src/index.ts --dts-only --clean --outDir dist/types",
    "lint": "eslint src",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "start": "storybook dev -p 6006",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:staged": "cross-env CI=true vitest related --passWithNoTests",
    "prepublishOnly": "pnpm build",
    "release": "release-it"
  },
  "dependencies": {
    "@carbon/ibm-products": "2.57.1",
    "@carbon/react": "1.77.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@stomp/stompjs": "6.1.2",
    "@tanstack/react-query": "^5.90.21",
    "@tippyjs/react": "4.2.6",
    "classnames": "2.3.2",
    "dayjs": "^1.11.11",
    "dompurify": "3.4.0",
    "downshift": "6.1.7",
    "lodash.get": "4.4.2",
    "lodash.isequal": "4.5.0",
    "lodash.sortby": "4.7.0",
    "match-sorter": "6.3.1",
    "react-modal": "3.16.1",
    "react-toastify": "9.1.1",
    "sanitize-html": "^2.17.3"
  },
  "peerDependencies": {
    "@carbon/react": "^1.75.0",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.16.0",
    "formik": "^2.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^5.3.4",
    "yup": ">=0.32.11"
  },
  "devDependencies": {
    "@carbon/react": "1.61.0",
    "@chromatic-com/storybook": "^5.1.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/addon-a11y": "10.3.4",
    "@storybook/addon-docs": "10.3.4",
    "@storybook/addon-links": "10.3.4",
    "@storybook/react-vite": "10.3.4",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^30.0.0",
    "@types/lodash.get": "^4.4.7",
    "@types/lodash.isequal": "^4.5.6",
    "@types/lodash.sortby": "^4.7.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^16.9.8",
    "@types/react-modal": "^3.13.1",
    "@types/react-router-dom": "5.3.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/testing-library__jest-dom": "^5.14.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@typescript-eslint/utils": "^8.56.1",
    "@vitejs/plugin-react": "^4.3.4",
    "axios": "^1.16.0",
    "axios-mock-adapter": "^2.1.0",
    "cpy": "8.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^10.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "10.3.4",
    "eslint-plugin-testing-library": "^7.16.0",
    "formik": "^2.4.6",
    "globals": "^17.3.0",
    "husky": "^8.0.1",
    "in-publish": "^2.0.1",
    "jest-axe": "^6.0.0",
    "jsdom": "^20.0.0",
    "lint-staged": "^16.4.0",
    "mock-socket": "^9.1.5",
    "postcss": "^8.5.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^5.3.4",
    "release-it": "^19.2.4",
    "rimraf": "^3.0.2",
    "rollup": "^4.60.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "sass": "^1.99.0",
    "storybook": "10.3.4",
    "tsup": "^8.5.1",
    "typescript": "^4.6.3",
    "vite": "^6.4.2",
    "vitest": "1.6.1",
    "yup": "^0.32.11"
  },
  "pnpm": {
    "overrides": {
      "@babel/helpers": "^7.26.10",
      "@babel/runtime": "7.28.6",
      "@tootallnate/once": "^3.0.1",
      "basic-ftp": "^5.3.0",
      "body-parser": "1.20.3",
      "braces": "3.0.3",
      "brace-expansion": "^5.0.5",
      "cross-spawn": "7.0.5",
      "defu": "^6.1.5",
      "flatted": "^3.4.2",
      "follow-redirects": "^1.16.0",
      "js-yaml": "4.1.1",
      "lodash": "4.18.1",
      "lodash-es": "4.18.1",
      "micromatch": "^4.0.8",
      "minimatch": "^10.2.4",
      "nanoid": "^3.3.8",
      "postcss": "^8.5.10",
      "qs": "6.15.0",
      "path-to-regexp@0.1": "0.1.12",
      "path-to-regexp@0": "1.9.0",
      "path-to-regexp@1": "1.9.0",
      "picomatch": "^4.0.4",
      "semver@7": "7.5.2",
      "tar": "7.5.6",
      "undici": "^6.24.0",
      "vite": "^6.4.2",
      "ws@6": "6.2.3",
      "ws@8": "8.17.1",
      "yaml": "2.8.3"
    }
  },
  "lint-staged": {
    "src/**/*": "prettier --write --ignore-unknown",
    "src/**/*.{js,jsx,ts,tsx}": [
      "pnpm lint",
      "pnpm test:staged"
    ]
  },
  "browserslist": {
    "production": [
      "defaults"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "release-it": {
    "github": {
      "release": true
    },
    "git": {
      "commitMessage": "chore: release v${version}",
      "requireCleanWorkingDir": false
    }
  }
}